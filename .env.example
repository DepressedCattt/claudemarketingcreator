# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit your actual keys.

# Google Gemini API key — used by scripts/analyze-ad.js
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key — used by scripts/generate-sfx.js for AI sound effects
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
